{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["uid", "email", "createdAt", "role"]
    },
    "SavedWord": {
      "title": "SavedWord",
      "description": "Words saved by the user for practice",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "word": { "type": "string" },
        "meaning": { "type": "string" },
        "kannadaTranslation": { "type": "string" },
        "pronunciation": { "type": "string" },
        "savedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "word", "savedAt"]
    },
    "LearningProgress": {
      "title": "LearningProgress",
      "description": "User's learning statistics",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "wordsLearned": { "type": "integer" },
        "quizzesTaken": { "type": "integer" },
        "averageScore": { "type": "number" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "wordsLearned", "quizzesTaken"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/users/{userId}/savedWords/{wordId}": {
      "schema": "SavedWord",
      "description": "Words saved by a specific user"
    },
    "/users/{userId}/progress/stats": {
      "schema": "LearningProgress",
      "description": "Learning statistics for a specific user"
    }
  }
}
